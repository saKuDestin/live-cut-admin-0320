# ==============================================================================
# live-cut-admin-0320 环境变量配置示例
# 复制此文件为 .env 并填入实际值
# ==============================================================================

# ---- 服务端环境变量 ----

# 应用模式（决定服务哪套前端静态文件）
#   admin（默认）  → 服务管理后台前端，对应域名 admini.seealso.online
#   client         → 服务用户端前端，对应域名 seealso.online
APP_MODE=admin

# 管理后台服务端口（默认 3002）
ADMIN_PORT=3002

# 管理后台 JWT 签名密钥（建议与主项目使用不同的密钥）
ADMIN_JWT_SECRET=your-admin-jwt-secret-here

# 主项目 .env 文件路径（用于读取/修改 API 配置）
# 默认值：../live-cut-test1/.env
MAIN_PROJECT_ENV=../live-cut-test1/.env

# 额外允许的 CORS 域名（逗号分隔，可选）
# 默认已内置：seealso.online, www.seealso.online, admini.seealso.online
# CORS_ALLOWED_ORIGINS=https://other-domain.com

# ---- 前端环境变量（VITE_ 前缀，会被打包进前端代码）----

# 管理后台 API 地址
# 子域名部署方案：
#   - 管理后台前端（admini.seealso.online）访问后端 API
#   - 如果前端和后端部署在同一台服务器且通过 Nginx 反代，留空即可（使用相对路径）
#   - 如果后端有独立域名（如 api.seealso.online），则填写完整 URL
VITE_ADMIN_API_URL=
