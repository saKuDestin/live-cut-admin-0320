# ==============================================================================
# live-cut-admin-0320 环境变量配置示例
# 复制此文件为 .env 并填入实际值
# ==============================================================================

# ---- 服务端环境变量 ----

# 管理后台服务端口（默认 3002）
ADMIN_PORT=3002

# 管理后台 JWT 签名密钥（建议与主项目使用不同的密钥）
ADMIN_JWT_SECRET=your-admin-jwt-secret-here

# 主项目 .env 文件路径（用于读取/修改 API 配置）
# 默认值：../live-cut-test1/.env
MAIN_PROJECT_ENV=../live-cut-test1/.env

# ---- 前端环境变量（VITE_ 前缀，会被打包进前端代码）----

# 管理后台 API 地址（跨域部署时必填）
# - 开发环境：留空，前端使用相对路径，由 Vite dev server 代理到 localhost:3002
# - 生产环境：填写后端服务的完整 URL，例如 https://api.seealso.online
#   注意：管理后台前端部署在 www.seealso.me，但 API 仍然访问同一个后端服务
VITE_ADMIN_API_URL=
