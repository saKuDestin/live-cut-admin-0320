# ==============================================================================
# live-cut-admin-0320 环境变量配置示例
# 复制此文件为 .env 并填入实际值
# ==============================================================================
#
# 路由架构说明（双路径分发）：
#   seealso.online/       → 前台客户端（dist/client）
#   seealso.online/admin  → 后台管理端（dist/admin）
#   seealso.online/api/admin/* → 后端 API 路由
#
# 构建命令：pnpm build
#   等价于：pnpm build:admin && pnpm build:client && pnpm build:server
# ==============================================================================

# ---- 服务端环境变量 ----

# 管理后台服务端口（默认 3002，Render 会通过 PORT 环境变量动态注入）
ADMIN_PORT=3002

# 管理后台 JWT 签名密钥（建议与主项目使用不同的密钥）
ADMIN_JWT_SECRET=your-admin-jwt-secret-here

# 主项目 .env 文件路径（用于读取/修改 API 配置）
# 默认值：../live-cut-test1/.env
MAIN_PROJECT_ENV=../live-cut-test1/.env

# ---- 前端环境变量（VITE_ 前缀，会被打包进前端代码）----

# 管理后台 API 地址
# 单域名方案（seealso.online）：前端和后端同域，留空即可（使用相对路径）
# 管理后台前端挂载在 /admin，API 路径为 /api/admin/*，均在同一域名下，无跨域问题
VITE_ADMIN_API_URL=
